# Copy to .env and adjust. All values are optional; defaults live in app/config.py.

# --- service ---
APP_NAME=SmartHaus
ENVIRONMENT=development
LOG_LEVEL=INFO
JSON_LOGS=false

# --- LLM (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
MODEL_NAME=llama3.1
TEMPERATURE=0.0
AGENT_TIMEOUT_SECONDS=60
